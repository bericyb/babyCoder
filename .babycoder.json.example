{
  "ai_provider": {
    "type": "lmstudio",
    "endpoint": "http://localhost:1234/v1",
    "model": "local-model",
    "temperature": 0.2
  },
  "agent": {
    "max_iterations": 10,
    "verbose": false
  },
  "project": {
    "root": ".",
    "exclude_patterns": [
      "vendor/",
      "**/*_test.go",
      "**/*.pb.go"
    ]
  },
  "prompts": {
    "main_agent": "",
    "sub_agent": ""
  }
}
